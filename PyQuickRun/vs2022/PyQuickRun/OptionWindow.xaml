<Window x:Class="PyQuickRun.OptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="No #pqr header found" Height="320" Width="420"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#F3F3F3">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="❓" FontSize="40" HorizontalAlignment="Center" Foreground="#007ACC"/>
            <TextBlock Text="No #pqr header found" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Category:" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtCategory" Height="26" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,15"
                         Tag="e.g. Utility, Tool, AI"/>

                <TextBlock Text="Execution Settings:" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                <CheckBox x:Name="ChkTerminal" Content="Run in Command Prompt (CMD)" Margin="0,2"/>
                <CheckBox x:Name="ChkCloseOnSuccess" Content="Close window after successful execution" Margin="0,2"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnRunNow" Content="Run Now (Ctrl+D)" Padding="20,6" Margin="0,0,10,0" Click="BtnRunNow_Click"/>
            <Button x:Name="BtnSaveRun" Content="Save &amp; Run (Ctrl+S)" Padding="20,6" Background="#007ACC" Foreground="White" Click="BtnSaveRun_Click"/>
        </StackPanel>
    </Grid>
</Window>
