<Window x:Class="PyQuickRun.OptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="No #pqr header found" SizeToContent="Height" Width="450"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#F3F3F3" ShowInTaskbar="False">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="❓" FontSize="40" HorizontalAlignment="Center" Foreground="#007ACC"/>
            <TextBlock Text="No #pqr header found" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Content Area -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Category:" FontSize="12" Foreground="#666" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtCategory" Height="28" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,15"
                         ToolTip="e.g. Utility, Tool, AI"/>

                <Separator Margin="0,5,0,15" Background="#EEE"/>

                <TextBlock Text="Next time this script will:" FontSize="12" Foreground="#666" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <CheckBox x:Name="ChkTerminal" Content="Run in Command Prompt (CMD)" Margin="0,4" Foreground="#333"/>
                <CheckBox x:Name="ChkCloseOnSuccess" Content="Close window after successful execution" Margin="0,4" Foreground="#333"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button x:Name="BtnRunNow" Content="Run Now (Ctrl+D)" Padding="20,8" Margin="0,0,12,0" Click="BtnRunNow_Click"
                    Background="#E1E1E1" BorderThickness="1" BorderBrush="#CCC"/>
            <Button x:Name="BtnSaveRun" Content="Save &amp; Run (Ctrl+S)" Padding="20,8" Background="#007ACC" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0" Click="BtnSaveRun_Click"/>
        </StackPanel>
    </Grid>
</Window>
